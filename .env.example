# Public frontend environment variables (read by Vite)
# Set your public app URL (used for canonical/SEO links)
VITE_SITE_URL="https://servicehubmaster.com"

# Optional: Google Analytics 4 measurement ID (example: G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=""

# Optional: webhook endpoints for form submissions (must allow CORS from your site)
VITE_BOOKING_WEBHOOK_URL=""
VITE_CONTACT_WEBHOOK_URL=""

# Optional: client-side Gemini API key for direct browser calls
# Prefer server-side usage for sensitive workflows.
VITE_GEMINI_API_KEY=""

