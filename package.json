{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:host": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rimraf dist .vite",
    "lint": "npm run check:encoding && npm run lint:types && npm run lint:eslint",
    "lint:types": "tsc --noEmit",
    "lint:eslint": "eslint . --max-warnings=0",
    "check": "npm run lint && npm run build",
    "stop:dev": "powershell -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "check:encoding": "node scripts/check-encoding.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.0"
  }
}
